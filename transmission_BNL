import os
import numpy as np

outdir = "transmission_dat_Thomas"
os.makedirs(outdir, exist_ok=True)

#Cell_3

def save_transmission(fns):
    fn = fns
    dt1=h5xs(fn, [de.detectors, de.qgrid])
    dt1.load_data()
    dt1.set_trans(trans_mode.external)
    for sample_name, sample_dict in dt1.d0s.items():
        if 'transmission' not in sample_dict:
            continue
    
        transmission = sample_dict['transmission']
    
        out_fn = os.path.join(outdir, f"{sample_name}_transmission.dat")
    
        # Save as one column
        np.savetxt(out_fn, transmission, fmt="%.6f")
    
        print(f"Wrote {out_fn}")
    dt1.fh5.close()

#Cell_4

save_transmission(fns="Thomas_zero_25_2.h5")
