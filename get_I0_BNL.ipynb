import numpy as np
import matplotlib.pyplot as plt
from scipy.stats import linregress

solvent_name = "Bkgrnd_100"
merged = dt1.d1s[solvent_name]["merged"]  # list[Data1d], len=30

# --- Average across frames ---
q = merged[0].qgrid
I = np.mean(np.vstack([d.data for d in merged]), axis=0)

# --- Guinier fit region ---
q_min_fit = 0.03
q_max_fit = 0.56

mask = (q >= q_min_fit) & (q <= q_max_fit) & (I > 0)
q_fit = q[mask]
I_fit = I[mask]

q2 = q_fit**2
lnI = np.log(I_fit)
fit = linregress(q2, lnI)
slope, intercept = fit.slope, fit.intercept
I0 = np.exp(intercept)

# --- Extrapolated Guinier curve ---
q_guinier = np.linspace(0, q_fit.max(), 200)
I_guinier = np.exp(slope * q_guinier**2 + intercept)

# --- Plot ---
fig, ax = plt.subplots(figsize=(6, 4))
ax.loglog(q, I, label=f"{solvent_name} (avg of {len(merged)} frames)")
ax.loglog(q_guinier[1:], I_guinier[1:], "r--", label=f"Guinier fit (I(0)≈{I0:.2e})")  # skip q=0 on log plot
ax.plot(q_guinier[1], I0, "ro")
ax.set_xlabel(r"q ($\AA^{-1}$)")
ax.set_ylabel("I")
ax.legend()
plt.tight_layout()
plt.show()

print("Estimated I(0) =", I0)
